---
import Layout from '../components/Layout.astro'
const certifications = [
  {
    title: "Cloud Computing Fundamentals",
    issuer: "IMBSkills",
    year: "2026",
    image: "/images/certs/cloud-computing-fundamentals.png",
    pdf: "/certs/IBMDesign20260617-30-2j412g.pdf"
  },
  {
    title: "Project Management Fundamentals",
    issuer: "IMBSkills",
    year: "2026",
    image: "images/certs/project-management-fundamentals.4.png",
    pdf: "/certs/ProjectManagementFundamentals_Badge20260618-32-op2vmv.pdf"
  },
  {
    title: "Digital Marketing Certified",
    issuer: "Hubspot Academy",
    year: "2026",
    image: "images/certs/hubspotacademy.png",
    pdf: "/certs/digitalmarketing.png"
  },
]

---

<Layout title="Lassi Karjalainen - Professional CV" lang="en">
  <!-- JSON-LD Structured Data for AI/Search Engines -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Lassi Karjalainen",
    "jobTitle": "Technology Management Student @ JYU",
    "email": "lassikarjalainen0@gmail.com",
    "telephone": "+358403566526",
    "sameAs": [
      "https://github.com/LKKarjalainen",
      "https://linkedin.com/in/username",
    ],
    "knowsLanguage": ["Finnish", "English", "Swedish"],
    "knowsAbout": ["JavaScript", "TypeScript", "React", "Astro", "Node.js", "Full-stack Development", "Web Development", "Software Architecture"],
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": "University of Jyväskylä"
    }
  }
  </script>

  <main class="cv-container">
    <!-- Header with Visual Stats -->
    <header class="cv-header">
      <div class="header-content">
        <div class="name-title">
          <h1>Lassi Karjalainen</h1>
          <p class="professional-title">Technology Management Student @ JYU</p>
        </div>
        <div class="contact-info">
          <a href="mailto:lassikarjalainen0@gmail.com" class="contact-link">lassikarjalainen0@gmail.com</a>
          <span class="separator">•</span>
          <a href="tel:+358403566526" class="contact-link">+358 40 356 6526</a>
          <span class="separator">•</span>
          <span class="location">Jyväskylä, Finland</span>
        </div>
        <div class="contact-links">
          <a href="https://github.com/LKKarjalainen" target="_blank" rel="noopener noreferrer">GitHub Profile</a>
          <a href="https://www.linkedin.com/in/lassikarjalainen/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
        
      </div>
      
      <!-- Visual Statistics -->
      <div class="stats-showcase">
        <div class="stat-card">
          <div class="stat-number">2+</div>
          <div class="stat-label">Years of Experience</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">5+</div>
          <div class="stat-label">Projects Delivered</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">5+</div>
          <div class="stat-label">Years of Student Organization Experience</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">10+</div>
          <div class="stat-label">Years of IT-hobby Experience</div>
        </div>
      </div>

      
    </header>

    <!-- Professional Summary -->
    <section class="cv-section summary-section" aria-labelledby="summary-heading">
      <div class="summary-card">
        <h2 id="summary-heading" class="summary-heading">Professional Summary</h2>
        <p class="summary-text">
          Software engineer and QA specialist with diverse experience spanning software development, test automation, quality assurance and DevOps. 
          Proficient in end-to-end software development lifecycle, from architecture and implementation to validation and deployment. 
          Demonstrated expertise in building robust automation frameworks using Robot Framework and Python, combined with hands-on development using modern technologies. 
          Served as subject matter expert and patent contributor on medical device software. 
          Master's student in Technology Management with Data Science specialization, bringing strategic thinking to technical implementation. 
          Passionate about delivering high-quality software through comprehensive testing practices and efficient automation.
        </p>
      </div>
    </section>

    <!-- Key Competencies - Visually Prominent -->
    <section class="cv-section competencies-section" aria-labelledby="competencies-heading">
      <h2 id="competencies-heading">Core Competencies</h2>
      <div class="competencies-grid">
        <span class="competency-tag">Test Automation</span>
        <span class="competency-tag">Python</span>
        <span class="competency-tag">Software Validation</span>
        <span class="competency-tag">Machine Learning</span>
        <span class="competency-tag">Software Testing</span>
        <span class="competency-tag">Linux Environments</span>
        <span class="competency-tag">Git & Version Control</span>
        <span class="competency-tag">Robot Framework</span>
        <span class="competency-tag">Rust</span>
        <span class="competency-tag">CI/CD</span>
        <span class="competency-tag">APIs</span>
        <span class="competency-tag">Database Design</span>
        <span class="competency-tag">Agile/Scrum</span>
        <span class="competency-tag">Code Review</span>
      </div>
    </section>

    <!-- Work Experience - AI-Optimized Format -->
    <section class="cv-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading">Work Experience</h2>
      
    <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Software Developer</h3>
            <p class="company" itemprop="hiringOrganization">USA Medical Electronix • Remote, Freelance</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2024-02">February 2024</time> – <time itemprop="endDate" datetime="2025-06">June 2025</time></span>
        </div>
        <ul class="achievements" itemprop="description">
          <li><strong>Other:</strong> Worked as a subject matter expert on the patent for the device and software</li>
          <li><strong>Development:</strong> Designed and developed the software for a medical device (Automated External Defibrillator) from start to finish</li>
          <li><strong>Collaboration:</strong> Worked in an small team with another developer, a supervisor, a software architect and the company leadership, shipping frequently with a lean approach to development resources and project management</li>
        </ul>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Test Automation Trainee</h3>
            <p class="company" itemprop="hiringOrganization">Airbus Defence and Space • Jyväskylä, Finland</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2024-05">May 2024</time> – <time itemprop="endDate" datetime="2024-09">September 2024</time></span>
        </div>
        <ul class="achievements" itemprop="description">
          <li><strong>Leadership:</strong> Guided and onboarded new trainees and refactored onboarding documentation for new employees and trainees</li>
          <li><strong>Development:</strong> Expanded and improved existing web automation. Explored alternative technologies for a new automation target</li>
          <li><strong>Collaboration:</strong> Worked in an Agile team with developers, a product owner, a software architect and scrum master, shipping 2-week sprints consistently</li>
        </ul>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Software Test Trainee</h3>
            <p class="company" itemprop="hiringOrganization">Airbus Defence and Space • Jyväskylä, Finland</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2023-05">May 2023</time> – <time itemprop="endDate" datetime="2023-09">September 2023</time></span>
        </div>
        <ul class="achievements" itemprop="description">
          <li><strong>Testing:</strong> Manually tested products both with a robust test set and through exploratory testing. Reported findings to development teams</li>
          <li><strong>Development:</strong> Built a robust integration of concurrent web automation alongside an existing mobile automation framework</li>
          <li><strong>Collaboration:</strong> Worked in an Agile team with developers, a product owner, a software architect and scrum master, shipping 2-week sprints consistently</li>
        </ul>
      </article>
    </section>

    <!-- Education - Structured Format -->
    <section class="cv-section" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>
      
      <article class="cv-entry" itemscope itemtype="https://schema.org/EducationalOccupationalCredential">
        <div class="entry-header">
          <div>
            <h3 itemprop="name">Master's Degree Programme in Technology Management, Information Technology</h3>
            <p class="company" itemprop="credentialCategory">University of Jyväskylä • Finland</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2025">2025</time> – <time itemprop="endDate" datetime="2025">Present</time></span>
        </div>
        <p class="details" itemprop="description">Minor in Economics<br>
        Specialization in Software Engineering <br>
        Relevant coursework: Software Engineering, Data Science and Machine Learning, Mathematical-logical thinking, Anticipation of Technological Development, Productization and Commercialization of Software, Innovation Management, Technology Entrepreneurship</p>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EducationalOccupationalCredential">
        <div class="entry-header">
          <div>
            <h3 itemprop="name">Bachelor of Technology - BTech, Information and Software Technology</h3>
            <p class="company" itemprop="credentialCategory">University of Jyväskylä • Finland</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2021">2021</time> – <time itemprop="endDate" datetime="2025">2025</time></span>
        </div>
        <p class="details" itemprop="description">Minor in Business Studies <br>
        Specialization in Data Science<br>
        Relevant coursework: Software Engineering, Data Science and Machine Learning, Web Development, Database Systems, Software Architecture, Algorithm Design, Mathematical-logical thinking, Innovation Management</p>
      </article>
      
    </section>

    <!-- Technical Skills - Proficiency Levels -->
    <section class="cv-section" aria-labelledby="skills-heading">
      <h2 id="skills-heading">Technical Skills</h2>
      <div class="skills-grid">
        <div class="skill-category">
          <h4>Test Automation & QA</h4>
          <ul class="skill-list">
            <li><strong>Expert:</strong> Python, Robot Framework, Test Automation, Web Automation</li>
            <li><strong>Proficient:</strong> Manual Testing, Exploratory Testing, Mobile Automation, CI/CD Integration</li>
            <li><strong>Familiar:</strong> Performance Testing, Test Data Management</li>
          </ul>
        </div>
        <div class="skill-category">
          <h4>Programming Languages</h4>
          <ul class="skill-list">
            <li><strong>Proficient:</strong> Python, Rust</li>
            <li><strong>Familiar:</strong> Java, SQL, Bash/Shell Scripting</li>
            <li><strong>Learning:</strong> Machine Learning frameworks, Advanced algorithms</li>
          </ul>
        </div>
        <div class="skill-category">
          <h4>Tools & Infrastructure</h4>
          <ul class="skill-list">
            <li><strong>Expert:</strong> Git, Linux Environments, VS Code</li>
            <li><strong>Proficient:</strong> CI/CD Pipelines, Docker, Database Design, APIs</li>
            <li><strong>Familiar:</strong> Cloud platforms, Container orchestration</li>
          </ul>
        </div>
        <div class="skill-category">
          <h4>Professional Competencies</h4>
          <ul class="skill-list">
            <li>Agile/Scrum Methodologies</li>
            <li>Technical Problem-Solving & Debugging</li>
            <li>Team Leadership & Mentoring</li>
            <li>Software Validation & Quality Assurance</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Certifications -->
    <section class="cv-section" aria-labelledby="certifications-heading">
      <h2 id="certifications-heading">Certifications</h2>
      <div class="certifications-grid">
        {certifications.map((cert) => (
          <article class="project-card cert-card">
            <div class="cert-top">
              {cert.image ? <img class="cert-image" src={cert.image} alt={`${cert.title} certificate`} /> : null}
              {cert.pdf ? (
                <span class="project-link"><a href={cert.pdf} target="_blank" rel="noopener noreferrer" download>Download</a></span>
              ) : null}
            </div>
            <div class="cert-body">
              <h3 class="cert-title">{cert.title}</h3>
              <p class="project-description">{cert.issuer} • {cert.year}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Volunteering Experience - AI-Optimized Format -->
    <section class="cv-section" aria-labelledby="volunteering-heading">
      <h2 id="volunteering-heading">Volunteering</h2>
      
      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Corporate Relations Coordinator of the Board</h3>
            <p class="company" itemprop="hiringOrganization">The Student Union of the University of Jyväskylä</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2026-01">January 2026</time> – <time itemprop="endDate" datetime="2026-12">December 2026</time></span>
        </div>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">General Active</h3>
            <p class="company" itemprop="hiringOrganization">Linkki Jyväskylä ry</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2026-01">January 2026</time> – <time itemprop="endDate" datetime="2026-12">December 2026</time></span>
        </div>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Chair of the board</h3>
            <p class="company" itemprop="hiringOrganization">Tietotekniikan Opiskelijoiden Liitto ry</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2025-01">January 2025</time> – <time itemprop="endDate" datetime="2025-12">December 2025</time></span>
        </div>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Project Manager</h3>
            <p class="company" itemprop="hiringOrganization">Linkki Jyväskylä ry</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2025-01">January 2025</time> – <time itemprop="endDate" datetime="2025-12">December 2025</time></span>
        </div>
      </article>
      
      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Secretary</h3>
            <p class="company" itemprop="hiringOrganization">Linkki Jyväskylä ry</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2024-01">January 2024</time> – <time itemprop="endDate" datetime="2024-12">December 2024</time></span>
        </div>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Excursion Coordinator</h3>
            <p class="company" itemprop="hiringOrganization">Algo ry</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2023-01">January 2023</time> – <time itemprop="endDate" datetime="2023-12">December 2023</time></span>
        </div>
      </article>

      <article class="cv-entry" itemscope itemtype="https://schema.org/EmployeeRole">
        <div class="entry-header">
          <div>
            <h3 itemprop="jobTitle">Corporate Relations Active</h3>
            <p class="company" itemprop="hiringOrganization">Algo ry</p>
          </div>
          <span class="date"><time itemprop="startDate" datetime="2022-10">October 2022</time> – <time itemprop="endDate" datetime="2022-12">December 2022</time></span>
        </div>
      </article>
    </section>

    <!-- Languages -->
    <section class="cv-section" aria-labelledby="languages-heading">
      <h2 id="languages-heading">Languages</h2>
      <div class="languages-grid">
        <div class="language-item">
          <strong>Finnish</strong> - Native Proficiency
        </div>
        <div class="language-item">
          <strong>English</strong> - Full Professional Proficiency (C1)
        </div>
        <div class="language-item">
          <strong>Swedish</strong> - Professional Working Proficiency (B1)
        </div>
      </div>
    </section>

    <!-- Projects Overview -->
    <section class="cv-section" aria-labelledby="projects-heading">
      <h2 id="projects-heading">Featured Projects</h2>
      
      <div class="projects-grid">
        
        <article class="project-card">
          <div class="project-header">
            <h3>Linkkibot TG-bot</h3>
            <span class="project-link"><a href="https://github.com/Linkkijkl/linkkibot" target="_blank" rel="noopener noreferrer">View on GitHub</a></span>
          </div>
          <p class="project-description">
            A telegram bot designed to automate event announcing and reminders. Made for Linkki Jyväskylä ry.
          </p>
          <div class="project-tech">
            <span class="tech-tag">Python</span>
            <span class="tech-tag">APIs</span>
          </div>
        </article>
        
        <article class="project-card">
          <div class="project-header">
            <h3>TiTOL-peli</h3>
            <span class="project-link"><a href="https://titolpeli.linkkijkl.fi" target="_blank" rel="noopener noreferrer">Try it out</a>
              <a href="https://github.com/LKKarjalainen/TiTOLpeli" target="_blank" rel="noopener noreferrer">View on GitHub</a></span>
            </div>
            <p class="project-description">
              A Godot based game made for TiTOL ry. The main idea is for teams to race against each other on a map and perform certain tasks as quickly as possible. Heavily inspired by Afrikan Tähti and Gimble.
            </p>
            <div class="project-tech">
              <span class="tech-tag">GDScript</span>
              <span class="tech-tag">GDShader</span>
              <span class="tech-tag">GitHub pipelines</span>
            </div>
          </article>

          <article class="project-card">
            <div class="project-header">
              <h3>Iltasoitto application</h3>
              <span class="project-link"><a href="https://github.com/LKKarjalainen/iltasoitto" target="_blank" rel="noopener noreferrer">View on GitHub</a></span>
            </div>
            <p class="project-description">
              An application that plays the Jyväskylä Iltasoitto from your phone's speaker at 20:00.
              Extremely WIP due to Android memory and battery management.
            </p>
            <div class="project-tech">
              <span class="tech-tag">Kotlin</span>
              <span class="tech-tag">Android</span>
            </div>
          </article>

        <article class="project-card">
          <div class="project-header">
