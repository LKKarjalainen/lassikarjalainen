            <span class="tech-tag">Astro</span>
            <span class="tech-tag">JavaScript</span>
            <span class="tech-tag">HTML</span>
            <span class="tech-tag">CSS</span>
          </div>
        </article>
      </div>
    </section>

  </main>
</Layout>

<style>
  .cv-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    color: #333;
    line-height: 1.65;
  }

  /* Header - Impressive First Impression */
  .cv-header {
    background: linear-gradient(125deg, #0066cc 0%, #0052a3 100%);
    color: white;
    padding: 2.5rem;
    border-radius: 12px;
    margin-bottom: 2.5rem;
    box-shadow: 0 10px 30px rgba(0, 102, 204, 0.15);
  }

  .header-content {
    margin-bottom: 2rem;
  }

  .name-title h1 {
    margin: 0 0 0.25rem 0;
    font-size: 3rem;
    color: white;
    font-weight: 800;
    letter-spacing: -0.8px;
  }

  .professional-title {
    margin: 0 0 1rem 0;
    font-size: 1.3rem;
    color: #e6f0ff;
    font-weight: 500;
  }

  .contact-info {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .contact-link {
    color: white;
    text-decoration: none;
    transition: all 0.2s;
    font-weight: 500;
  }

  .contact-link:hover {
    color: #e6f0ff;
    text-decoration: underline;
  }

  .separator {
    color: #b3d9ff;
  }

  .location {
    color: #e6f0ff;
  }

  .contact-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }

  .contact-links a {
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.15);
  }

  .contact-links a:hover {
    background-color: rgba(255, 255, 255, 0.25);
    text-decoration: none;
  }

  /* Stats Showcase - Immediate Impact */
  .stats-showcase {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .stat-card {
    background-color: rgba(255, 255, 255, 0.15);
    padding: 1.5rem;
    border-radius: 8px;
    text-align: center;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #ffeb3b;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.9rem;
    color: #e6f0ff;
    font-weight: 500;
  }

  /* Competencies Section */
  .competencies-section {
    color: white;
    margin-bottom: 2.5rem;
  }

  .competencies-grid {
    display: flex;
