---
const { title, lang } = Astro.props;
const pathname = Astro.url.pathname;
const currentLang = lang ?? (pathname.startsWith('/en/') ? 'en' : 'fi');
const showLangToggle = pathname === '/' || pathname === '/en/' || pathname === '/en';
const toggleHref = currentLang === 'en' ? '/' : '/en/';
const toggleLabel = currentLang === 'en' ? 'Suomeksi' : 'English';
---
<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title}` : 'Lassi Karjalainen'}</title>
  <link rel="stylesheet" href="/global.css">
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="navbutton">Home</a>
      <a href="/cv" class="navbutton">CV</a>
      <a href="/meemuja" class="navbutton meemuja">Meemuja</a>
      {showLangToggle ? <a href={toggleHref} class="navbutton right-justify">{toggleLabel}</a> : null}
    </header>
    <slot />
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Lassi Karjalainen</p>
    </footer>
  </body>
  </html>
